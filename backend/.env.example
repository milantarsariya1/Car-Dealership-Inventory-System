# Copy this file to .env and fill in real values before running the backend.

# PostgreSQL connection string (Neon, local Postgres, or Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/dealership?schema=public"

# Secret used to sign JWT tokens — REQUIRED, the server refuses to start without it.
# Generate one with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret"

# Port for the Express server (defaults to 5000)
PORT=5000
